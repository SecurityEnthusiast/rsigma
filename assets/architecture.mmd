flowchart TD
    YAML["YAML input"]
    SERDE["yaml_serde"]
    EVENTS["Log events"]
    OUTPUT["EvaluationResult\nRuleHeader: title · id · level · tags\nResultBody: Detection (matched fields/selections) ·\nCorrelation (correlation_type · group_key · aggregated_value)"]
    QUERIES["SQL · SPL · KQL · Lucene"]
    EDITOR["Editor diagnostics + code actions"]
    LEGEND["* = feature-gated\n** = requires daachorse-index feature"]

    subgraph rsigma-parser
        direction TB
        PARSE["parser.rs (YAML → AST)"] -->|"SigmaRule · CorrelationRule\nFilterRule · SigmaCollection"| PEST["sigma.pest (PEG grammar)\ncondition.rs (Pratt parser)"]
        PARSE --> VALUE["value.rs\nSigmaStr · wildcards · timespan"]
        PARSE --> AST["ast.rs\nAST types · modifiers · enums"]
    end

    subgraph rsigma-eval
        direction TB
        ETRAIT["Event trait\nJsonEvent · KvEvent · PlainEvent"]
        ETRAIT --> EPIPE["pipeline/\nPipeline · conditions · transformations\nstate · finalizers\nbuiltin: ecs_windows · sysmon\ndynamic: ${source.*} template expansion"]
        EPIPE --> ECOMP["compiler/\ncompile_rule → CompiledRule\nmatcher optimizer (AnyOf):\nAho-Corasick batching (|contains)\nRegexSet batching (|re)\nCaseInsensitiveGroup"]
        ECOMP --> EENG["engine/\nEngine (stateless)\nprefilters:\nRuleIndex (exact-value pruning)\nbloom trigram filter* (substring)\ncross-rule AC index** (daachorse)"]
        EENG --> ECORR["correlation/\nsliding windows · group-by\nchaining · suppression"]
        ECORR --> ECUST["rsigma.* custom attributes"]
    end

    subgraph rsigma-convert
        direction TB
        CBACK["Backend trait\npluggable query generation"]
        CBACK --> CTQC["TextQueryConfig\n~90 fields for text query backends"]
        CTQC --> CWALK["Condition walker\ndeferred exprs · conversion state"]
        CWALK --> CENDS["backends/\nTextQueryTest · PostgreSQL/TimescaleDB\nLynxDB"]
    end

    subgraph rsigma-lsp
        direction TB
        LSERV["LSP server over stdio\ntower-lsp"]
        LSERV --> LDIAG["diagnostics\nlint + parse + compile"]
        LDIAG --> LFEAT["completions · hover\ndocument symbols"]
        LFEAT --> LEDIT["Editors\nVSCode · Neovim · Helix · Zed"]
    end

    subgraph rsigma-runtime
        direction TB
        RINPUT["input/ format adapters:\nJSON · syslog · logfmt* · CEF* · EVTX*\nplain text · auto-detect\nraw line → EventInputDecoded"]
        RINPUT --> RPROC["LogProcessor\nbatch evaluation\nArcSwap hot-reload (rules + pipelines)\nMetricsHook · EventFilter"]
        RPROC --> RENG["RuntimeEngine\nwraps Engine + CorrelationEngine\nwith rule loading"]
        RENG --> RIO["io/\nEventSource (stdin · HTTP · NATS)\nOTLP* (HTTP + gRPC)\nSink (stdout · file · NATS) · DLQ"]
        RSRC["sources/ (dynamic pipelines)\nSourceResolver: HTTP · command · file · NATS\nTemplateExpander · SourceCache (SQLite TTL)\nRefreshScheduler: interval · watch · push\nSIGHUP · NATS control · includes\nextract: jq · JSONPath · CEL"]
    end

    YAML -->|"Raw YAML Value"| SERDE
    SERDE --> PARSE
    PEST --> ETRAIT
    PEST --> CBACK
    PEST --> LSERV
    ECUST --> RENG
    EVENTS --> RINPUT
    RIO --> OUTPUT
    CENDS --> QUERIES
    LEDIT --> EDITOR
    RSRC -.->|"${source.*} values"| EPIPE
